.vscode/
*.swp
*.swo
*~

# Logs and caches
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.tmp/
tmp/
temp/

# Dependencies and build output (common if you add JS/Python tooling)
node_modules/
dist/
build/
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
coverage/
.coverage
*.egg-info/
