# Environment and API keys — use .env (never commit). Template: .env.example
.env
.env.*
!.env.example

# Expanded / local MCP JSON (may contain real keys after envsubst)
mcp-config.*.local.json
mcp-config.generated.json
mcp-config.expanded.json

# OS
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# Local Claude/Cursor settings (nested tools)
**/.claude/settings.local.json

# Editors and IDEs
.idea/
.vscode/
*.swp
*.swo
*~

# Logs and caches
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.tmp/
tmp/
temp/

# Dependencies and build output (common if you add JS/Python tooling)
node_modules/
dist/
build/
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
coverage/
.coverage
*.egg-info/

# Local resized reference exports (large binaries)
refs-resized/
seedance-refs/

# Local media — working copies; do not commit (except canonical example below)
*.mp4
*.mov
*.webm
*.wav
*.mp3
*.m4a

# Canon Seedance song-chunk example (public raw URLs for video_files refs)
!drown-in-this-river-seedance-chunks/
!drown-in-this-river-seedance-chunks/**